  <text x="65" y="128" text-anchor="middle" font-family="Georgia,serif" font-size="10" fill="#fce7f3" opacity="0.9" style="fill:rgb(252, 231, 243);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:Georgia, serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">THE STAR</text>
  <line x1="22" y1="140" x2="108" y2="140" stroke="#f472b6" stroke-width="0.7" opacity="0.5" style="fill:rgb(0, 0, 0);stroke:rgb(244, 114, 182);color:rgb(0, 0, 0);stroke-width:0.7px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.5;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
