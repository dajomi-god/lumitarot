  <rect x="8" y="8" width="104" height="174" rx="6" fill="none" stroke="#f472b6" stroke-width="0.6" opacity="0.4" style="fill:none;stroke:rgb(244, 114, 182);color:rgb(0, 0, 0);stroke-width:0.6px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.4;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="60" y="88" text-anchor="middle" font-family="Georgia,serif" font-size="32" fill="#f472b6" opacity="0.85" style="fill:rgb(244, 114, 182);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:Georgia, serif;font-size:32px;font-weight:400;text-anchor:middle;dominant-baseline:auto">☀</text>
  <text x="60" y="118" text-anchor="middle" font-family="Georgia,serif" font-size="9" fill="#fce7f3" opacity="0.7" style="fill:rgb(252, 231, 243);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.7;font-family:Georgia, serif;font-size:9px;font-weight:400;text-anchor:middle;dominant-baseline:auto">THE SUN</text>
</g>

<!-- 앞 가운데 카드 -->
<g transform="translate(280, 42)" style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">
  <rect width="130" height="205" rx="10" fill="#22003a" stroke="#f9a8d4" stroke-width="2" style="fill:rgb(34, 0, 58);stroke:rgb(249, 168, 212);color:rgb(0, 0, 0);stroke-width:2px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <rect x="9" y="9" width="112" height="187" rx="7" fill="none" stroke="#f472b6" stroke-width="0.8" opacity="0.5" style="fill:none;stroke:rgb(244, 114, 182);color:rgb(0, 0, 0);stroke-width:0.8px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.5;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
